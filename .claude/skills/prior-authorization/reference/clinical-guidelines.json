      "required_documentation": [
        {
          "item": "Headache diary or migraine frequency documentation",
          "requirement": "≥90-day record documenting migraine frequency",
          "required": true
        },
        {
          "item": "Disability scale",
          "requirement": "MIDAS or HIT-6 score documenting significant impairment",
          "required": true
        }
      ],
      "step_therapy": {
