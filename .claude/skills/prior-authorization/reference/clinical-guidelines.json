    },
    {
      "guideline_id": "GL-AD-BIOLOGIC-004",
      "name": "Atopic Dermatitis — Biologic Therapy",
      "version": "v2.1",
      "effective": "2026-01-01",
      "tier": "Step Therapy",
      "treatments_covered": [
        "Dupilumab (Dupixent)",
        "Tralokinumab (Adbry)",
        "Lebrikizumab (Ebglyss)"
      ],
      "approved_indications": {
        "icd10_codes": ["L20.0", "L20.81", "L20.82", "L20.89", "L20.9"],
        "descriptions": ["Atopic dermatitis — moderate to severe"]
      },
      "severity_criteria": {
        "minimum_severity": "Moderate to severe",
        "validated_tools": ["EASI ≥16", "IGA ≥3", "SCORAD ≥25", "DLQI ≥10 (quality of life impact)"],
        "requirement": "At least one validated severity score required"
      },
      "required_labs": [
        {
          "test": "Total IgE (optional but supportive)",
          "threshold": "Elevated >100 IU/mL supports atopic diagnosis",
          "max_age_months": 12,
          "required": false
        },
        {
          "test": "EASI or IGA score (clinical assessment)",
          "threshold": "EASI ≥16 or IGA ≥3",
          "max_age_months": 3,
          "required": true
        }
      ],
      "step_therapy": {
        "required": true,
        "minimum_agents": 2,
        "minimum_duration_months": 3,
        "required_agents_sequence": [
          {
            "category": "Topical corticosteroid (TCS)",
            "examples": ["Triamcinolone 0.1%", "Betamethasone", "Clobetasol"],
            "min_duration_months": 3,
            "acceptable_failure": "Inadequate control OR skin atrophy/adverse effects"
          },
          {
            "category": "Topical calcineurin inhibitor (TCI) or PDE4 inhibitor",
            "examples": ["Tacrolimus", "Pimecrolimus", "Crisaborole"],
            "min_duration_months": 3,
            "acceptable_failure": "Inadequate control"
          }
        ],
        "note": "Oral immunosuppressants (cyclosporine, methotrexate) may substitute for second step in severe cases"
      },
      "dosing_limits": {
        "dupilumab_adults": "300mg q2wk (after 600mg loading dose)",
        "max_coverage_months": 12
      },
      "contraindications": [
        "Active helminth infection (treat before initiating)"
      ],
      "escalation_flags": [
        "Age <6 (pediatric — separate dosing and indications)",
        "Concurrent use of another biologic",
        "Ocular surface disease requiring separate evaluation"
      ],
      "auto_adjudication_eligible": true
    },
    {
      "guideline_id": "GL-ASTHMA-BIOLOGIC-005",
      "name": "Severe Asthma — Anti-IL-5 / Anti-IL-4 Biologics",
      "version": "v3.1",
      "effective": "2026-01-01",
      "tier": "Step Therapy",
      "treatments_covered": [
        "Mepolizumab (Nucala)",
        "Benralizumab (Fasenra)",
        "Dupilumab (Dupixent) — asthma indication",
        "Tezepelumab (Tezspire)"
      ],
      "approved_indications": {
        "icd10_codes": ["J45.51", "J45.50", "J45.901"],
        "descriptions": ["Severe persistent asthma", "Uncontrolled asthma on ICS+LABA"]
      },
      "required_labs": [
        {
          "test": "Blood eosinophil count",
          "threshold": "≥150 cells/μL for anti-IL-5 agents; ≥300 preferred for optimal response",
          "max_age_months": 12,
          "required": "For mepolizumab and benralizumab"
        },
        {
          "test": "FeNO (Fractional exhaled NO)",
          "threshold": "≥25 ppb supports eosinophilic inflammation",
          "max_age_months": 12,
          "required": false
        }
      ],
      "step_therapy": {
        "required": true,
        "description": "Must be on maximally tolerated ICS+LABA ≥12 months with persistent uncontrolled asthma",
        "required_baseline": [
          "High-dose inhaled corticosteroid (ICS)",
          "Long-acting beta-agonist (LABA)"
        ],
        "documentation_required": [
          "≥2 asthma exacerbations requiring systemic corticosteroids in past 12 months OR",
          "Continuous oral corticosteroid dependence OR",
          "≥1 hospitalization for asthma in past 12 months"
        ]
      },
      "dosing_limits": {
        "mepolizumab": "100mg subcutaneous every 4 weeks",
        "max_coverage_months": 12,
        "response_assessment": "Required at 6 months — 50% reduction in exacerbations expected"
      },
      "contraindications": [
        "Acute asthma attack (not for rescue)",
        "Active parasitic infection"
      ],
      "escalation_flags": [
        "Eosinophil count <150 cells/μL (may still qualify for tezepelumab)",
        "History of Churg-Strauss syndrome or EGPA",
        "Age <6"
      ],
      "auto_adjudication_eligible": true
    },
    {
      "guideline_id": "GL-IMAGING-MRI-SPINE-006",
      "name": "MRI Spine — Lumbar / Cervical / Thoracic",
      "version": "v5.0",
      "effective": "2026-01-01",
      "tier": "Standard",
      "treatments_covered": [
        "MRI Lumbar Spine without contrast (72148)",
        "MRI Lumbar Spine with contrast (72149)",
        "MRI Cervical Spine without contrast (72141)",
        "MRI Thoracic Spine without contrast (72146)"
      ],
      "approved_indications": {
        "icd10_codes": ["M54.5", "M54.51", "M54.4", "M47.816", "M51.16", "G54.4", "M54.2"],
        "descriptions": ["Low back pain", "Neck pain", "Radiculopathy", "Disc herniation"]
      },
      "criteria": {
        "conservative_therapy": {
          "description": "Must have failed conservative therapy",
          "options": [
            "Physical therapy ≥4 weeks AND",
            "NSAID trial ≥2 weeks"
          ]
        },
        "clinical_indicators": {
          "one_of_required": [
            "Neurological deficit (weakness, numbness, reflex changes on exam)",
            "Radiculopathy with dermatomal distribution",
            "Suspicion of serious pathology (red flags)"
          ]
        },
        "red_flags_immediate_approval": [
          "Cauda equina syndrome (bowel/bladder dysfunction + saddle anesthesia)",
          "Suspicion of spinal cord compression",
          "Cancer history with new back pain",
          "Unexplained fever + back pain (discitis/osteomyelitis)",
          "Unexplained weight loss + back pain",
          "Fracture after trauma",
          "Age >70 with acute onset (compression fracture risk)"
        ]
      },
      "timeline": {
        "acute_pain_wait": "4-6 weeks of conservative therapy before routine MRI",
        "exception": "Red flags allow immediate MRI without wait period"
      },
      "contraindications_for_procedure": [
        "Implanted pacemaker (non-MRI-conditional)",
        "Cochlear implant (non-MRI-conditional)",
        "Ferromagnetic foreign body"
      ],
      "escalation_flags": [
        "Request within 4 weeks of onset without red flags",
        "Third MRI in 12 months for same region"
      ],
      "auto_adjudication_eligible": true
    },
    {
      "guideline_id": "GL-MIGRAINE-CGRP-007",
