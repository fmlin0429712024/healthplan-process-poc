        "note": "Behavioral/lifestyle interventions must be documented prior to pharmacotherapy"
      },
      "contraindications": [
        "Personal or family history of MTC",
        "MEN2",
        "Pregnancy (category X)",
        "Severe renal impairment (eGFR <15)"
      ],
