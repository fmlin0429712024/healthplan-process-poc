    {
      "guideline_id": "GL-IBD-BIOLOGIC-008",
      "name": "Inflammatory Bowel Disease — Biologic Therapy",
      "version": "v3.1",
      "effective": "2026-01-01",
      "tier": "Step Therapy",
      "treatments_covered": [
        "Infliximab (Remicade)",
        "Adalimumab (Humira) — IBD indication",
        "Vedolizumab (Entyvio)",
        "Ustekinumab (Stelara) — IBD indication",
        "Risankizumab (Skyrizi) — IBD indication"
      ],
      "approved_indications": {
        "icd10_codes": ["K50.00", "K50.10", "K50.80", "K51.00", "K51.90", "K50.90"],
        "descriptions": ["Crohn's disease", "Ulcerative colitis"]
      },
      "disease_activity_criteria": {
        "crohn_active": [
          "CRP >8 mg/L OR ESR >20 mm/hr AND",
          "Fecal calprotectin >250 μg/g OR",
          "CDAI >220 OR",
          "Colonoscopy with documented active inflammation"
        ],
        "uc_active": [
          "Mayo score ≥6 (moderate-severe)",
          "Endoscopic Mayo subscore ≥2"
        ]
      },
      "required_labs": [
        {
          "test": "CRP",
          "threshold": ">8 mg/L for active disease (or documented endoscopic activity)",
          "max_age_months": 3,
          "required": true
        },
        {
          "test": "Fecal calprotectin",
          "threshold": ">250 μg/g for active intestinal inflammation",
          "max_age_months": 3,
          "required": "If CRP borderline"
        },
        {
          "test": "HBsAg",
          "threshold": "Negative required",
          "max_age_months": 12,
          "required": true
        },
        {
          "test": "QuantiFERON-TB",
          "threshold": "Negative required",
          "max_age_months": 12,
          "required": true
        }
      ],
      "step_therapy": {
        "required": true,
        "crohn_sequence": [
          "Corticosteroid (prednisone/budesonide) — for induction only, not step therapy",
