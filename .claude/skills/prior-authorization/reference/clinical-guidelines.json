    {
      "guideline_id": "GL-RA-BIOLOGIC-001",
      "name": "Rheumatoid Arthritis — Biologic Therapy",
      "version": "v4.2",
      "effective": "2026-01-01",
      "tier": "Step Therapy",
      "treatments_covered": [
        "Adalimumab (Humira)",
        "Etanercept (Enbrel)",
        "Certolizumab (Cimzia)",
        "Golimumab (Simponi)",
        "Abatacept (Orencia)",
        "Secukinumab (Cosentyx)",
        "Upadacitinib (Rinvoq)",
        "Tofacitinib (Xeljanz)"
      ],
      "approved_indications": {
        "icd10_codes": ["M05.60", "M05.70", "M05.79", "M06.00", "M06.09", "M05.00", "M05.09"],
        "descriptions": ["Rheumatoid arthritis with rheumatoid factor", "RA without rheumatoid factor", "Seronegative RA"]
      },
      "required_labs": [
        {
          "test": "Rheumatoid Factor (RF)",
          "threshold": ">20 IU/mL for seropositivity (not required if anti-CCP positive)",
          "max_age_months": 12,
          "required": "At least one of RF or anti-CCP"
        },
        {
          "test": "Anti-CCP",
          "threshold": ">20 units for seropositivity",
          "max_age_months": 12,
          "required": "At least one of RF or anti-CCP"
        },
        {
          "test": "CRP or ESR",
          "threshold": "CRP >8 mg/L OR ESR >20 mm/hr",
          "max_age_months": 6,
          "required": true
        },
        {
          "test": "Hepatitis B surface antigen (HBsAg)",
          "threshold": "Negative required",
          "max_age_months": 12,
          "required": true
        },
        {
          "test": "QuantiFERON-TB Gold or PPD",
          "threshold": "Negative required (or documented treatment if positive)",
          "max_age_months": 12,
          "required": true
        }
      ],
      "step_therapy": {
        "required": true,
        "minimum_agents": 2,
        "minimum_duration_months": 3,
        "required_agents": [
          {
            "name": "Methotrexate",
            "alternative_names": ["MTX"],
            "min_dose": "10mg/week",
            "min_duration_months": 3,
            "acceptable_failure_reasons": ["Inadequate response", "Intolerance", "Contraindication"]
          }
        ],
        "additional_agents_from": [
          "Hydroxychloroquine", "Sulfasalazine", "Leflunomide"
        ],
        "exception": "Step therapy waived if documented contraindication to all conventional DMARDs with specialist attestation"
      },
      "dosing_limits": {
        "adalimumab": {"standard": "40mg q2wk", "max": "80mg q2wk for severe cases"},
        "etanercept": {"standard": "50mg/week"},
        "max_coverage_months": 12,
        "renewal_required_after_months": 12
      },
      "contraindications": [
        "Active TB or untreated latent TB",
        "Active serious infection",
        "Active hepatitis B infection",
        "Live vaccine within 3 months",
        "Concurrent use of another biologic or JAK inhibitor"
      ],
      "escalation_flags": [
        "Age <18 (pediatric indication — separate guideline applies)",
        "Concurrent biologic use",
        "History of lymphoma or other malignancy within 5 years",
        "Demyelinating disease",
        "NYHA Class III/IV heart failure"
      ],
      "auto_adjudication_eligible": true,
      "nurse_review_cases": "ESCALATE flags, off-label indications, combination biologics"
    },
    {
      "guideline_id": "GL-DM-GLP1-002",
      "name": "Type 2 Diabetes — GLP-1 Receptor Agonists",
      "version": "v3.0",
      "effective": "2026-01-01",
      "tier": "Step Therapy",
      "treatments_covered": [
        "Semaglutide (Ozempic) — diabetes indication",
        "Liraglutide (Victoza)",
        "Dulaglutide (Trulicity)",
        "Exenatide (Bydureon)",
        "Tirzepatide (Mounjaro)"
      ],
      "approved_indications": {
        "icd10_codes": ["E11.9", "E11.65", "E11.8", "E11.00", "E11.649"],
        "descriptions": ["Type 2 diabetes mellitus"]
      },
      "required_labs": [
        {
          "test": "HbA1c",
          "threshold": "≥7.5% (or ≥7.0% with documented cardiovascular risk requiring CVOT-proven agent)",
          "max_age_months": 3,
          "required": true
        },
        {
          "test": "eGFR",
          "threshold": ">30 mL/min/1.73m² (contraindicated in severe renal impairment)",
          "max_age_months": 6,
          "required": true
        },
        {
          "test": "Fasting blood glucose",
          "threshold": "Required for baseline documentation",
          "max_age_months": 3,
          "required": true
        }
      ],
      "step_therapy": {
        "required": true,
        "minimum_agents": 2,
        "minimum_duration_months": 3,
        "required_first_line": [
          {
            "name": "Metformin",
            "min_dose": "500mg BID or maximum tolerated dose",
            "min_duration_months": 3,
            "acceptable_failure_reasons": ["Inadequate glycemic control (HbA1c ≥7.5%)", "Intolerance", "Contraindication (eGFR <30)"]
          }
        ],
        "required_second_line": [
          "Sulfonylurea (glipizide, glimepiride, glyburide)",
          "DPP-4 inhibitor (sitagliptin, saxagliptin)",
          "SGLT2 inhibitor (empagliflozin, dapagliflozin)"
        ],
        "note": "At least one second-line agent must be documented prior to GLP-1 initiation, unless CVOT benefit is the primary clinical driver"
      },
      "dosing_limits": {
        "semaglutide_ozempic": {"max_dose": "2mg weekly", "titration": "Start 0.25mg, titrate over 4 weeks"},
        "max_coverage_months": 12
      },
      "contraindications": [
        "Personal or family history of medullary thyroid carcinoma (MTC)",
        "MEN2 (Multiple Endocrine Neoplasia type 2)",
        "History of pancreatitis (relative contraindication — requires clinical review)",
        "eGFR <30 mL/min/1.73m²",
        "Type 1 diabetes (not covered under this guideline)"
      ],
      "escalation_flags": [
        "History of pancreatitis",
        "Active gallbladder disease",
        "Simultaneous use of sulfonylurea (hypoglycemia risk — dose adjustment note required)",
        "HbA1c >12% (may require insulin intensification instead)"
      ],
      "auto_adjudication_eligible": true
    },
    {
      "guideline_id": "GL-OB-GLP1-003",
      "name": "Obesity / Weight Management — GLP-1 Agonists",
      "version": "v2.0",
      "effective": "2026-01-01",
      "tier": "Step Therapy",
      "treatments_covered": [
        "Semaglutide (Wegovy) 2.4mg — weight management indication",
