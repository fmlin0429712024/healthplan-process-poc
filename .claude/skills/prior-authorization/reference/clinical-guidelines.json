          "Corticosteroid",
          "Immunomodulator (AZA or 6-MP) ≥3 months",
          "THEN: biologic initiation"
        ],
        "exception": "Severe/fulminant disease — direct biologic initiation acceptable with specialist attestation"
      },
      "contraindications": [
        "Active serious infection including TB",
        "Active hepatitis B",
        "NYHA Class III/IV heart failure (for TNF inhibitors)",
        "Concurrent biologic"
      ],
      "escalation_flags": [
        "Pediatric (<18) — dosing differences",
        "Prior biologic failure — may qualify for different mechanism",
        "Cancer history — risk-benefit required"
      ],
      "auto_adjudication_eligible": true
    },
